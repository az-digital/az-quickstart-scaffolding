{
    "name": "az-digital/az-quickstart-scaffolding",
    "description": "Arizona Quickstart Scaffolding for Composer",
    "type": "project",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Arizona Digital",
            "homepage": "http://digital.arizona.edu/",
            "role": "Team"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "package",
            "package": {
                "name": "npm-asset/blazy",
                "version": "1.8.2",
                "dist": {
                    "url": "https://registry.npmjs.org/blazy/-/blazy-1.8.2.tgz",
                    "type": "tar"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "npm-asset/bootstrap-datepicker",
                "version": "1.10.1",
                "dist": {
                    "url": "https://registry.npmjs.org/bootstrap-datepicker/-/bootstrap-datepicker-1.10.1.tgz",
                    "type": "tar"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "npm-asset/easepick--bundle",
                "version": "1.2.1",
                "dist": {
                    "url": "https://registry.npmjs.org/@easepick/bundle/-/bundle-1.2.1.tgz",
                    "type": "tar"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "npm-asset/jquery-ui-touch-punch",
                "version": "dev-master",
                "source": {
                    "url": "https://github.com/furf/jquery-ui-touch-punch.git",
                    "type": "git",
                    "reference": "master"
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "npm-asset/slick-carousel",
                "version": "1.6.0",
                "dist": {
                    "url": "https://registry.npmjs.org/slick-carousel/-/slick-carousel-1.6.0.tgz",
                    "type": "tar"
                }
            }
        }
    ],
    "require": {
        "php": ">=8.3",
        "az-digital/az_quickstart": "~3.3",
        "composer/installers": "2.3.0",
        "cweagans/composer-patches": "1.7.3",
        "drupal/core-composer-scaffold": "~11.2.0",
        "drush/drush": "^13.6.0",
        "oomphinc/composer-installers-extender": "2.0.1",
        "vlucas/phpdotenv": "5.6.2",
        "webflo/drupal-finder": "^1.2.2"
    },
    "require-dev": {
        "az-digital/az-quickstart-dev": "~3",
        "drupal/core-dev": "~11.2.0"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "secure-http": true,
        "disable-tls": false,
        "github-protocols": ["https"],
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "oomphinc/composer-installers-extender": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true
        }
    },
    "autoload": {
        "classmap": [
            "scripts/composer/ScriptHandler.php"
        ],
        "files": ["load.environment.php"]
    },
    "scripts": {
        "pre-install-cmd": [
            "QuickstartProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "pre-update-cmd": [
            "QuickstartProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "post-install-cmd": [
            "QuickstartProject\\composer\\ScriptHandler::createRequiredFiles"
        ],
        "post-update-cmd": [
            "QuickstartProject\\composer\\ScriptHandler::createRequiredFiles"
        ],
        "phpcs": [
            "phpcs -p --colors --standard=web/profiles/custom/az_quickstart/phpcs.xml.dist"
        ]
    },
    "extra": {
        "composer-exit-on-patch-failure": true,
        "enable-patching": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/profiles/custom/{$name}": ["type:drupal-custom-profile"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"],
            "drush/Commands/contrib/{$name}": ["type:drupal-drush"]
        },
        "drupal-scaffold": {
            "allowed-packages": ["az-digital/az_quickstart"],
            "file-mapping": {
                "[project-root]/.editorconfig": {
                    "path": "web/core/assets/scaffold/files/editorconfig",
                    "overwrite": false
                },
                "[project-root]/.gitattributes": {
                    "path": "web/core/assets/scaffold/files/gitattributes",
                    "overwrite": false
                }
            },
            "gitignore": false,
            "locations": {
                "web-root": "web/"
            }
        }
    }
}
